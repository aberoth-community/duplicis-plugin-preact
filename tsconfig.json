{
  "extends": "@duplicis/config/tsconfig.app.json",
  "compilerOptions": {
    /* project */
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.tsbuildinfo",

    /* paths */
    "rootDir": "./",
    "baseUrl": "./",
    "noEmit": true,

    /* typechecking */
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
